<%
const title = 'Tomato Atlas Toy';
const mainClass = 'tomato-toy-main';
const hideFooter = true;
const h = value => String(value ?? '').replace(/[&<>"']/g, char => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;'
}[char]));
const allToyVarieties = toyVarieties || [];
const featured = allToyVarieties.find(variety => variety.imageUrl) || allToyVarieties[0] || {};
const safeToyData = JSON.stringify(allToyVarieties).replace(/</g, '\\u003c');
const safeToyMeta = JSON.stringify({
    totalCount: totalCount || allToyVarieties.length,
    scrapedAt,
    source,
    stats: toyStats || {}
}).replace(/</g, '\\u003c');
const mealOptions = [
    ['sauce', 'Sauce'],
    ['salad', 'Salad'],
    ['sandwich', 'Sandwich'],
    ['salsa', 'Salsa'],
    ['pizza', 'Pizza'],
    ['soup', 'Soup'],
    ['canning', 'Canning'],
    ['roasting', 'Roasted'],
    ['fine_dining', 'Fine plate'],
    ['snack', 'Snack']
];
const body = `
<section id="tomatoToy" class="tomato-toy" style="--tomato-primary: ${h(featured.color?.primary || '#b7352c')}; --tomato-secondary: ${h(featured.color?.secondary || '#e35b3f')};">
    <script id="tomato-toy-data" type="application/json">${safeToyData}</script>
    <script id="tomato-toy-meta" type="application/json">${safeToyMeta}</script>

    ${allToyVarieties.length === 0 ? `
        <div class="toy-empty-state">
            <p class="eyebrow">No varieties loaded</p>
            <h1>The tomato toy needs data first.</h1>
            <p>Run <code>cd backend && python scraper.py</code>, then restart the API server.</p>
        </div>
    ` : `
        <div class="toy-topline">
            <a class="toy-brand" href="/" aria-label="Tomato Atlas Toy home">
                <span class="brand-mark"></span>
                <span>Tomato Atlas Toy</span>
            </a>
            <div class="toy-meta-strip">
                <span>${h(totalCount || allToyVarieties.length)} varieties</span>
                <span>${h(toyStats?.attributeCount || 52)} attributes</span>
                <span>${h(toyStats?.imageCount || 0)} real photos</span>
            </div>
        </div>

        <div class="toy-workspace">
            <section class="tomato-stage" aria-labelledby="stage-title">
                <div class="stage-copy">
                    <p class="eyebrow">Interactive specimen finder</p>
                    <h1 id="stage-title">Drag flavor, season, shape, and meal intent until one tomato turns into another.</h1>
                </div>

                <div class="morph-lab" aria-live="polite">
                    <div class="morph-specimen" id="morphSpecimen" role="img" aria-label="Morphing tomato specimen">
                        <span class="rib rib-one"></span>
                        <span class="rib rib-two"></span>
                        <span class="rib rib-three"></span>
                        <span class="tomato-gloss"></span>
                    </div>
                    <div class="morph-orbit" aria-hidden="true">
                        <span>sweetness</span>
                        <span>density</span>
                        <span>season</span>
                        <span>rarity</span>
                    </div>
                </div>

                <div class="selected-specimen">
                    <div class="selected-image" id="selectedImageWrap">
                        ${featured.imageUrl ? `<img id="selectedImage" src="${h(featured.imageUrl)}" alt="${h(featured.imageAlt || featured.name)}">` : `<div id="selectedImage" class="image-fallback"></div>`}
                    </div>
                    <div>
                        <p class="eyebrow" id="selectedSource">${h(featured.imageSource || 'Image pending')}</p>
                        <h2 id="selectedName">${h(featured.name || 'Tomato')}</h2>
                        <p id="selectedDescription">${h(featured.description || 'Move the controls to discover a better match.')}</p>
                        <div class="selected-tags" id="selectedTags"></div>
                    </div>
                </div>
            </section>

            <aside class="toy-controls" aria-label="Tomato finder controls">
                <div class="control-header">
                    <p class="eyebrow">Perfect Tomato Finder</p>
                    <button class="icon-action" type="button" id="perfectFinderBtn" title="Find the most surprising match">
                        <i class="fas fa-wand-magic-sparkles"></i>
                    </button>
                </div>

                <label class="search-field">
                    <span>Search the archive</span>
                    <input id="toySearch" type="search" placeholder="Cherokee, striped, paste, sweet...">
                </label>

                <div class="axis-row">
                    <div class="axis-pad" data-axis-pad="flavor" aria-label="Flavor four-way access control">
                        <button class="axis-thumb" type="button" aria-label="Flavor thumb"></button>
                        <span class="axis-label top">Juicy</span>
                        <span class="axis-label right">Sweet</span>
                        <span class="axis-label bottom">Meaty</span>
                        <span class="axis-label left">Tart</span>
                    </div>
                    <div class="axis-pad" data-axis-pad="garden" aria-label="Season and plant four-way access control">
                        <button class="axis-thumb" type="button" aria-label="Garden thumb"></button>
                        <span class="axis-label top">Early</span>
                        <span class="axis-label right">Sprawl</span>
                        <span class="axis-label bottom">Late</span>
                        <span class="axis-label left">Pot</span>
                    </div>
                </div>

                <div class="range-bank">
                    <label>
                        <span>Bitter to sweet</span>
                        <input id="sweetnessRange" type="range" min="0" max="100" value="68">
                    </label>
                    <label>
                        <span>Visual strangeness</span>
                        <input id="dramaRange" type="range" min="0" max="100" value="52">
                    </label>
                    <label>
                        <span>Garden forgiveness</span>
                        <input id="easeRange" type="range" min="0" max="100" value="48">
                    </label>
                </div>

                <div class="select-grid">
                    <label>
                        <span>Location</span>
                        <select id="locationSelect">
                            <option value="any">Anywhere</option>
                            <option value="northeast">Northeast summer</option>
                            <option value="humid">Humid garden</option>
                            <option value="hot">Hot patio</option>
                            <option value="cool">Cool short season</option>
                            <option value="container">Container balcony</option>
                        </select>
                    </label>
                    <label>
                        <span>Time of year</span>
                        <select id="seasonSelect">
                            <option value="any">Any season</option>
                            <option value="spring">Spring planning</option>
                            <option value="early">Early harvest</option>
                            <option value="peak">Peak summer</option>
                            <option value="late">Late season</option>
                            <option value="winter">Winter pantry</option>
                        </select>
                    </label>
                </div>

                <div class="meal-selector" role="group" aria-label="Meal selector">
                    ${mealOptions.map(([value, label], index) => `
                        <button type="button" class="meal-chip ${index === 0 ? 'active' : ''}" data-meal="${value}">${label}</button>
                    `).join('')}
                </div>
            </aside>
        </div>

        <section class="result-panel" aria-labelledby="results-title">
            <div class="result-heading">
                <div>
                    <p class="eyebrow">Live ranking</p>
                    <h2 id="results-title">Best matches right now</h2>
                </div>
                <div class="result-count" id="resultCount"></div>
            </div>
            <div class="tomato-results" id="tomatoResults"></div>
        </section>
    `}
</section>
`;
%>

<%- include('layout', { title, body, mainClass, hideFooter }) %>
