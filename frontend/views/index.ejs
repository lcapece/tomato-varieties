<%
const title = 'Tomato Intelligence Platform';
const mainClass = 'tomato-intelligence-main';
const hideFooter = true;
const h = value => String(value ?? '').replace(/[&<>"']/g, char => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;'
}[char]));
const allVarieties = toyVarieties || [];
const featured = allVarieties.find(variety => /brandywine/i.test(variety.name || '') && variety.imageUrl)
    || allVarieties.find(variety => variety.imageUrl)
    || allVarieties[0]
    || {};
const safeData = JSON.stringify(allVarieties).replace(/</g, '\\u003c');
const safeMeta = JSON.stringify({
    totalCount: totalCount || allVarieties.length,
    scrapedAt,
    source,
    region: 'United States · New York',
    imagePolicy: 'Supabase private storage with signed URL delivery is the target production image path.'
}).replace(/</g, '\\u003c');

const imagePool = allVarieties.filter(variety => variety.imageUrl).slice(0, 16);
const modeImages = {
    buy: ['/images/generated/tomato-bg-buy.png', ...imagePool.slice(0, 3).map(variety => variety.imageUrl)],
    grow: ['/images/generated/tomato-bg-grow.png', ...imagePool.slice(4, 7).map(variety => variety.imageUrl)],
    cook: ['/images/generated/tomato-bg-cook.png', ...imagePool.slice(8, 11).map(variety => variety.imageUrl)],
    compare: ['/images/generated/tomato-bg-compare.png', ...imagePool.slice(12, 15).map(variety => variety.imageUrl)]
};
const safeModeImages = JSON.stringify(modeImages).replace(/</g, '\\u003c');

const body = `
<section id="tomatoIntelligenceApp" class="tomato-intelligence-app" style="--tomato-primary: ${h(featured.color?.primary || '#b8342f')}; --tomato-secondary: ${h(featured.color?.secondary || '#df6a43')};">
    <script id="tomato-intelligence-data" type="application/json">${safeData}</script>
    <script id="tomato-intelligence-meta" type="application/json">${safeMeta}</script>
    <script id="tomato-intelligence-mode-images" type="application/json">${safeModeImages}</script>

    ${allVarieties.length === 0 ? `
        <div class="ti-empty-state">
            <p class="ti-eyebrow">Data unavailable</p>
            <h1>Tomato intelligence needs the backend archive first.</h1>
            <p>Start the Python API and refresh this app shell.</p>
        </div>
    ` : `
        <div class="ti-atmosphere" aria-hidden="true">
            <div class="ti-bg ti-bg-a"></div>
            <div class="ti-bg ti-bg-b"></div>
            <div class="ti-bg-overlay"></div>
        </div>

        <div class="ti-shell" data-shell>
            <header class="ti-topbar">
                <a class="ti-brand" href="/" aria-label="Tomato Intelligence Platform">
                    <span class="ti-brand-mark" aria-hidden="true"></span>
                    <span>Tomato Intelligence</span>
                </a>
                <label class="ti-search">
                    <span class="sr-only">Search tomato varieties, traits, and uses</span>
                    <input data-search type="search" placeholder="Search varieties, traits, uses..." autocomplete="off">
                </label>
                <nav class="ti-mode-switcher" aria-label="Current intent">
                    <button type="button" data-mode="buy">Buy</button>
                    <button type="button" data-mode="grow">Grow</button>
                    <button type="button" data-mode="cook">Cook</button>
                    <button type="button" data-mode="compare">Compare</button>
                </nav>
                <button type="button" class="ti-chip-button" data-location-panel>United States · New York</button>
                <button type="button" class="ti-chip-button" data-sources-panel>Sources</button>
                <button type="button" class="ti-icon-button" data-favorites aria-label="Favorites">♡</button>
            </header>

            <div class="ti-main-canvas">
                <aside class="ti-left-panel" aria-label="Tomato search and filters">
                    <div class="ti-panel-head">
                        <p class="ti-eyebrow">Discovery</p>
                        <strong data-result-count>${h(allVarieties.length)} varieties</strong>
                    </div>
                    <div class="ti-filter-tabs" role="group" aria-label="Filter tomatoes">
                        <button type="button" data-filter="all">All</button>
                        <button type="button" data-filter="slicer">Slicer</button>
                        <button type="button" data-filter="sauce">Sauce</button>
                        <button type="button" data-filter="easy">Easy</button>
                    </div>
                    <div class="ti-source-groups" data-source-groups></div>
                    <div class="ti-variety-list" data-variety-list></div>
                </aside>

                <main class="ti-center-panel" aria-live="polite">
                    <section class="ti-hero-card">
                        <p class="ti-eyebrow" data-mode-label>Buy Tomatoes</p>
                        <h1 data-selected-name>${h(featured.name || 'Tomato')}</h1>
                        <p data-selected-summary>${h(featured.description || 'A cataloged tomato variety ready for practical decision support.')}</p>
                        <div class="ti-tag-row" data-selected-tags></div>
                    </section>

                    <section class="ti-intelligence-grid">
                        <article class="ti-guidance-card" data-guidance="shelf">
                            <span>Shelf Reality</span>
                            <h2>Stores sell tomato types, not guaranteed cultivars.</h2>
                            <p data-shelf-copy></p>
                        </article>
                        <article class="ti-guidance-card" data-guidance="garden">
                            <span>Garden Reality</span>
                            <h2>Regional timing matters more than catalog optimism.</h2>
                            <p data-garden-copy></p>
                        </article>
                        <article class="ti-guidance-card" data-guidance="kitchen">
                            <span>Kitchen Reality</span>
                            <h2>Flavor and texture decide the right use.</h2>
                            <p data-kitchen-copy></p>
                        </article>
                    </section>

                    <section class="ti-score-panel" aria-labelledby="score-title">
                        <div>
                            <p class="ti-eyebrow">Decision fingerprint</p>
                            <h2 id="score-title">Six practical axes</h2>
                        </div>
                        <div class="ti-radar-wrap">
                            <svg class="ti-radar" viewBox="0 0 220 220" role="img" aria-labelledby="radar-title radar-desc">
                                <title id="radar-title">Tomato fingerprint radar</title>
                                <desc id="radar-desc" data-radar-desc>Accessible score summary updates when a variety is selected.</desc>
                                <polygon class="ti-radar-grid" points="110,18 187,62 187,150 110,194 33,150 33,62"></polygon>
                                <polygon class="ti-radar-mid" points="110,48 161,77 161,135 110,164 59,135 59,77"></polygon>
                                <polygon class="ti-radar-shape" data-radar-shape points="110,42 160,82 158,136 110,168 60,136 62,82"></polygon>
                            </svg>
                            <div class="ti-axis-list" data-axis-list></div>
                        </div>
                    </section>
                </main>

                <aside class="ti-right-panel" aria-label="Visual tomato identity">
                    <div class="ti-image-frame" data-image-frame>
                        ${featured.imageUrl ? `<img src="${h(featured.imageUrl)}" alt="${h(featured.imageAlt || featured.name || 'Tomato variety')}" loading="eager">` : `<div class="ti-image-fallback"></div>`}
                    </div>
                    <div class="ti-visual-card">
                        <p class="ti-eyebrow">Visual identity</p>
                        <h2 data-visual-title>${h(featured.name || 'Tomato')}</h2>
                        <p data-visual-copy></p>
                        <small data-image-policy>Production images should resolve through private Supabase buckets and signed URLs.</small>
                    </div>
                </aside>
            </div>

            <footer class="ti-compare-tray" aria-label="Compare queue">
                <div>
                    <span>Compare Queue</span>
                    <strong data-compare-count>0 selected</strong>
                </div>
                <div class="ti-compare-items" data-compare-items></div>
                <button type="button" class="ti-primary" data-add-compare>Add current</button>
            </footer>
        </div>
    `}
</section>
`;
%>

<%- include('layout', { title, body, mainClass, hideFooter }) %>
